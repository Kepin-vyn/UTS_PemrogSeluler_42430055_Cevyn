<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- EditText Nama Dosen -->
    <!-- Added android:autofillHints="name" for autofill support -->
    <!-- Changed app:layout_constraintWidth_max to 488dp to comply with Material Design recommendations -->
    <EditText
        android:id="@+id/editTextNamaDosen"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/hint_nama_dosen"
        android:padding="16dp"
        android:inputType="textPersonName"
        android:autofillHints="name"
        app:layout_constraintWidth_max="488dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btnMasuk"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Button Masuk -->
    <Button
        android:id="@+id/btnMasuk"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_masuk"
        app:layout_constraintStart_toEndOf="@+id/editTextNamaDosen"
        app:layout_constraintTop_toTopOf="@+id/editTextNamaDosen"
        app:layout_constraintBottom_toBottomOf="@+id/editTextNamaDosen"
        android:layout_marginStart="16dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>
